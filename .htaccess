# ----------------------------------------------------------------------
# Home2First — clean URLs (serve pages without the .html extension)
# Works on Hostinger (LiteSpeed) / Apache via mod_rewrite.
# ----------------------------------------------------------------------
RewriteEngine On

# Send /index and /index.html to the canonical site root "/"
RewriteCond %{THE_REQUEST} \s/+index(\.html)?[\s?] [NC]
RewriteRule ^ / [R=301,L]

# 301-redirect any direct /name.html request to the extensionless /name
RewriteCond %{THE_REQUEST} \s/+([^.\s]+)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Internally serve /name from name.html (only when name.html actually exists)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
